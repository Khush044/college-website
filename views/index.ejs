<%- include('partials/header') %>

<section class="hero fade-in">
  <div class="container hero-content">
    <h1>Transform Your <span style="color: #60a5fa;">Future</span> Today</h1>
    <p>Join a community of innovators and leaders. Get access to world-class education and industry-leading mentors.</p>
    <div class="hero-actions" style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;">
      <a href="/courses" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2rem;">Explore Programs <i class="fas fa-arrow-right"></i></a>
      <a href="/apply" class="btn btn-secondary" style="font-size: 1.1rem; padding: 1rem 2rem;">Start Application</a>
    </div>
  </div>
</section>

<section class="info-section">
  <div class="container">
    <div style="text-align: center; margin-bottom: 4rem;">
      <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Why Choose GT University?</h2>
      <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">We provide the tools, environment, and network to help you succeed in the global landscape.</p>
    </div>
    
    <div class="grid">
      <div class="card fade-in" style="animation-delay: 0.1s;">
        <div class="card-icon"><i class="fas fa-user-tie"></i></div>
        <h3>Expert Faculty</h3>
        <p>Learn from internationally recognized professors and industry practitioners who bring real-world experience to the classroom.</p>
      </div>
      <div class="card fade-in" style="animation-delay: 0.2s;">
        <div class="card-icon"><i class="fas fa-microscope"></i></div>
        <h3>Cutting-edge Research</h3>
        <p>Participate in groundbreaking research projects in our state-of-the-art laboratories and innovation centers.</p>
      </div>
      <div class="card fade-in" style="animation-delay: 0.3s;">
        <div class="card-icon"><i class="fas fa-globe-americas"></i></div>
        <h3>Global Opportunities</h3>
        <p>Build an international career with our network of global partners and exchange programs across 30+ countries.</p>
      </div>
    </div>
  </div>
</section>

<section style="background: #fff; padding: 100px 0;">
  <div class="container">
    <div style="display: flex; align-items: center; gap: 4rem; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 300px;">
        <img src="/images/library.png" alt="Campus Life" style="width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);">
      </div>
      <div style="flex: 1; min-width: 300px;">
        <span style="color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">Campus Life</span>
        <h2 style="font-size: 2.5rem; margin: 1rem 0 1.5rem;">A Community Beyond Academics</h2>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">Education at GT University goes beyond the classroom. From 50+ student clubs to international cultural fests, discover a vibrant lifestyle that helps you grow personally and professionally.</p>
        <ul style="list-style: none; margin-bottom: 2rem;">
          <li style="margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem;">
            <i class="fas fa-check-circle" style="color: var(--success);"></i> 50+ Student-led Organizations
          </li>
          <li style="margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem;">
            <i class="fas fa-check-circle" style="color: var(--success);"></i> Olympic-sized Sports Facilities
          </li>
          <li style="margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem;">
            <i class="fas fa-check-circle" style="color: var(--success);"></i> 24/7 Modern Library Access
          </li>
        </ul>
        <a href="/contact" class="btn btn-primary">Schedule a Visit</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
